# Copy this to .env and fill in your actual values
# DO NOT commit .env to version control

# Discord Bot Token - Get from https://discord.com/developers/applications
TOKEN=YOUR_BOT_TOKEN_HERE

# Discord Application ID
CLIENT_ID=1522533189204054026

# Channel IDs for status updates
STATUS_CHANNEL_ID=123456789012345678
PLAYER_CHANNEL_ID=123456789012345679
UPTIME_CHANNEL_ID=123456789012345680

# Minecraft Server Configuration
HOST=nigeruson.aternos.me
PORT=23793

# Optional: Role ID to ping when server comes online
