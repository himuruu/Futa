# Copy this to .env and fill in your actual values
# DO NOT commit .env to version control

# Discord Bot Token - Get from https://discord.com/developers/applications
TOKEN=YOUR_BOT_TOKEN_HERE

# Discord Application ID
CLIENT_ID=1522533189204054026

# Channel IDs for status updates
STATUS_CHANNEL_ID=123456789012345678
PLAYER_CHANNEL_ID=123456789012345679
UPTIME_CHANNEL_ID=123456789012345680

# Minecraft Server Configuration
# Preferred: configure the Aternos session and server cookies below.
# These are used to query the Aternos status page directly.
ATERNOS_SESSION_COOKIE=your_session_cookie_here
ATERNOS_SERVER_COOKIE=your_server_cookie_here

# Optional override for a custom Aternos status URL.
# ATERNOS_STATUS_URL=https://example.com/status

# Optional fallback: if cookies are not available, the bot can probe the Minecraft port directly.
# Aternos Java servers commonly use 25565.
HOST=nigeruson.aternos.me
PORT=25565

# Optional: Role ID to ping when server comes online
# ROLE_ID=123456789012345681

# Optional: Channel ID for notifications
# CHANNEL_ID=123456789012345682

# Optional: Bedrock Edition Port
# BEDROCK_PORT=19132
